# Prisma（開発: SQLite）
DATABASE_URL="file:./dev.db"

# POST /api/sync と設定画面の手動同期に共通で使う認証シークレット
# 本番では必須。設定画面では実行時に同じ値を入力する。
# SYNC_API_SECRET="your-random-secret-here"

# AZA.GG 深境螺旋統計（公開KV API。現在はAPIキー不要）
AZA_API_BASE_URL="https://c1-api.aza.gg"
AZA_ABYSS_ENABLED="true"
AZA_CACHE_TTL_SECONDS="21600"
AZA_REQUEST_TIMEOUT_MS="10000"
