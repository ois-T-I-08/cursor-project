# Prisma / Neon PostgreSQL
# 通常のNext.js実行はNeon pooled connection、Migrationはdirect connectionを使う。
# ここでは秘密を含まない形式例のみを記載する。
DATABASE_URL="postgresql://app_user:replace-me@ep-example-pooler.ap-northeast-1.aws.neon.tech/genshin?sslmode=require"
DIRECT_URL="postgresql://app_user:replace-me@ep-example.ap-northeast-1.aws.neon.tech/genshin?sslmode=require"

# POST /api/sync と設定画面の手動同期に共通で使う認証シークレット
# 本番では必須。設定画面では実行時に同じ値を入力する。
# SYNC_API_SECRET="your-random-secret-here"

# AZA.GG 深境螺旋統計（公開KV API。現在はAPIキー不要）
AZA_API_BASE_URL="https://c1-api.aza.gg"
AZA_ABYSS_ENABLED="true"
AZA_CACHE_TTL_SECONDS="21600"
AZA_REQUEST_TIMEOUT_MS="10000"

# Flutter release buildからこのNext.js backendへ接続するための公開origin。
# ReleaseではGitHub Secretへ同名で登録し、HTTPSを必須とする。AZA.GGのURLではない。
# 以下は秘密情報を含まないダミー値。localhostはローカル開発時のdart-defineだけで使用する。
GENSHIN_BUILDER_API_BASE_URL="https://builder.example.com"

# gcsim 編成推薦（既定は無効。固定バイナリとmigration確認後だけ有効化する）
GCSIM_ENABLED="false"
GCSIM_MAX_CANDIDATES="20"
GCSIM_MAX_CONCURRENCY="2"
GCSIM_MAX_ACTIVE_JOBS="8"
GCSIM_TIMEOUT_SECONDS="30"
GCSIM_ITERATIONS="1000"
GCSIM_CACHE_TTL_SECONDS="86400"
GCSIM_JOB_TTL_SECONDS="86400"
GCSIM_MAX_CONFIG_BYTES="65536"
GCSIM_MAX_OUTPUT_BYTES="2097152"
GCSIM_DURATION_SECONDS="90"

# 推薦スコア係数（合計1.0でない場合は安全な既定値へ戻る）
GCSIM_SCORE_PERFORMANCE="0.35"
GCSIM_SCORE_OBSERVED="0.20"
GCSIM_SCORE_BUILD="0.15"
GCSIM_SCORE_STABILITY="0.10"
GCSIM_SCORE_ENERGY="0.10"
GCSIM_SCORE_ACCESSIBILITY="0.10"

# YShelper統計Collector
# 正式な利用許可・URL・fixture確認後に、URL・adapter・個別kill switchを明示する。
# 初期状態ではADAPTER_MODEを空、個別kill switchをfalseに保つ。
YSHELPER_API_BASE_URL=""
YSHELPER_ABYSS_ENDPOINT=""
YSHELPER_STYGIAN_ENDPOINT=""
YSHELPER_ADAPTER_MODE=""
# YSHELPER_API_TOKEN="optional-token"
YSHELPER_ABYSS_ENABLED="false"
YSHELPER_STYGIAN_ENABLED="false"
YSHELPER_REQUEST_TIMEOUT_MS="15000"
YSHELPER_MAX_RESPONSE_BYTES="4194304"
YSHELPER_SYNC_INTERVAL_DAYS="14"
# YSHELPER_COLLECT_SECRET="replace-with-a-random-secret"
