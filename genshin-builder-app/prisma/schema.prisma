// Prisma スキーマ（Neon PostgreSQL）
// 通常実行は pooled connection、Migration は direct connection を使用する。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// マスターデータ（外部APIから同期して保存する）
// ============================================================

/// キャラクターの基本情報
model Character {
  id         String   @id // APIのスラッグ（例: "hu-tao"）
  name       String
  element    String // 元素（pyro / hydro / electro / cryo / anemo / geo / dendro）
  weaponType String // 武器種（sword / claymore / polearm / bow / catalyst）
  rarity     Int // レアリティ（4 or 5）
  region     String // 出身地域（Mondstadt など）
  iconUrl    String // アイコン画像URL
  scoreType  String @default("atk") // 聖遺物スコア計算タイプ（atk / hp / def / em）
  syncedAt   DateTime @updatedAt // 最終同期日時

  upgrade CharacterUpgrade?
  progresses UserProgress[]
}

/// 武器の基本情報
model Weapon {
  id         String   @id
  name       String
  weaponType String
  rarity     Int
  iconUrl    String
  syncedAt   DateTime @updatedAt

  upgrade WeaponUpgrade?
}

/// 素材の基本情報
model Material {
  id        String   @id
  name      String
  category  String // 種類（talent-book / boss-material / local-specialties など）
  rarity    Int? // レアリティ（APIに存在する場合のみ）
  iconUrl   String
  expValue  Int? // 経験値（キャラ/武器強化素材。API material detail から取得）
  expTarget String? // character / weapon（経験値素材の対象）
  syncedAt  DateTime @updatedAt
}

/// キャラクター突破・天賦強化データ（API avatar detail から同期）
model CharacterUpgrade {
  characterId String    @id
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  /// JSON: PromoteStage[]（突破段階ごとの costItems / coinCost）
  promotes    String
  /// JSON: TalentUpgradeData[]（スキル種別ごとのレベル別 costItems）
  talents     String
  syncedAt    DateTime  @updatedAt
}

/// 武器突破データ（API weapon detail から同期）
model WeaponUpgrade {
  weaponId String @id
  weapon   Weapon @relation(fields: [weaponId], references: [id], onDelete: Cascade)
  /// JSON: PromoteStage[]
  promotes String
  /// JSON: string[]（レベルアップ用魔鉱などの material ID）
  levelUpItemIds String @default("[]")
  syncedAt DateTime @updatedAt
}

/// 目盛り間の必要EXP（character=全キャラ共通 rarity0 / weapon=レアリティ別）
model LevelExpSegment {
  id          String @id // 例: character-0-1-20, weapon-5-40-50
  targetType  String // character / weapon
  rarity      Int    @default(0)
  fromLevel   Int
  toLevel     Int
  expRequired Int
  moraRequired Int
  syncedAt    DateTime @updatedAt

  @@unique([targetType, rarity, fromLevel, toLevel])
}

// ============================================================
// ユーザーデータ（マスターデータとは別管理）
// ============================================================

/// ユーザーごとのキャラクター育成状況
/// Ver.1 ではログインなし。ブラウザに保存した匿名IDを userId として使う。
model UserProgress {
  id          String  @id @default(cuid())
  userId      String // 匿名ユーザーID
  characterId String
  character   Character @relation(fields: [characterId], references: [id])

  level       Int     @default(1) // レベル (1-90)
  ascension   Int     @default(0) // 突破段階 (0-6)
  constellation Int   @default(0) // 命ノ星座（凸数 0-6）
  talentNormal Int    @default(1) // 天賦：通常攻撃 (1-10)
  talentSkill  Int    @default(1) // 天賦：元素スキル (1-10)
  talentBurst  Int    @default(1) // 天賦：元素爆発 (1-10)
  weaponId    String  @default("") // 装備武器のマスターID
  weaponName  String  @default("") // 装備武器名（表示用）
  weaponLevel Int     @default(1) // 武器レベル (1-90)
  weaponRefinement Int @default(1) // 精錬ランク (1-5)
  artifacts   String  @default("") // 聖遺物データ（JSON文字列。SQLiteはJson型非対応のため）
  isCompleted Boolean @default(false) // 育成完了フラグ
  memo        String  @default("")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // 同じユーザーが同じキャラを重複登録できないようにする
  @@unique([userId, characterId])
  @@index([userId])
}

/// マスターデータ同期の実行履歴（デバッグ・Cron監視用）
model SyncLog {
  id        Int      @id @default(autoincrement())
  status    String // "success" / "error"
  detail    String // 同期件数やエラーメッセージ
  createdAt DateTime @default(now())
}

/// マスタ同期の分散リースロック（複数インスタンス間の排他）
model SyncLease {
  lockKey     String   @id
  ownerToken  String
  acquiredAt  DateTime
  expiresAt   DateTime
}

/// 外部APIの最終正常レスポンス（障害時フォールバック用）
model ExternalApiCache {
  cacheKey   String   @id
  source     String
  version    String
  sampleSize Int
  payload    String
  fetchedAt  DateTime
  expiresAt  DateTime
  updatedAt  DateTime @updatedAt
}

/// gcsimを含むおすすめ編成生成Job。HoYoLABのUID/Cookie/未加工レスポンスは保存しない。
model TeamSimulationJob {
  id           String   @id
  requestHash  String
  attackerId   String
  status       String
  result       String   @default("")
  errorCode    String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime

  @@index([requestHash, status])
  @@index([expiresAt])
}

/// 同一の正規化済み戦闘入力に対する最終正常結果。
model TeamSimulationCache {
  cacheKey      String   @id
  gcsimVersion  String
  attackerId    String
  payload       String
  createdAt     DateTime @default(now())
  expiresAt     DateTime
  updatedAt     DateTime @updatedAt

  @@index([attackerId])
  @@index([expiresAt])
}

/// YShelper 統計収集の実行履歴。秘密情報や upstream 本文は保存しない。
model BattleStatsSyncRun {
  id                       String   @id @default(cuid())
  source                   String
  status                   String
  startedAt                DateTime @default(now())
  finishedAt               DateTime?
  lastSuccessfulAt         DateTime?
  previousSuccessfulRunId  String?
  attemptedContentTypes    Json
  responseStatus           Int?
  sourceVersion            String?
  payloadHash              String?
  recordCount              Int      @default(0)
  validationState          String
  validationErrors         Json
  errorCode                String?
  errorDetail              String?
  createdAt                DateTime @default(now())

  previousSuccessfulRun BattleStatsSyncRun?  @relation("BattleStatsPreviousSuccessfulRun", fields: [previousSuccessfulRunId], references: [id], onDelete: SetNull)
  followingRuns         BattleStatsSyncRun[] @relation("BattleStatsPreviousSuccessfulRun")
  snapshots             BattleStatsSnapshot[]

  @@index([source, status, startedAt])
  @@index([previousSuccessfulRunId])
}

/// 検証結果を含む履歴スナップショット。Manifest が指したものだけを公開する。
model BattleStatsSnapshot {
  id               String   @id @default(cuid())
  source           String
  contentType      String
  seasonId         String
  revision         Int
  schemaVersion    Int
  payloadHash      String
  sourceVersion    String?
  sourceUpdatedAt  DateTime
  fetchedAt        DateTime
  validatedAt      DateTime
  publishedAt      DateTime?
  validationState  String
  sampleSize       Int?
  metadata         Json
  syncRunId        String

  syncRun        BattleStatsSyncRun          @relation(fields: [syncRunId], references: [id], onDelete: Restrict)
  teamUsages     BattleTeamUsage[]
  characterUsage BattleCharacterUsage[]
  manifest       BattleStatsManifest?

  @@unique([source, contentType, seasonId, payloadHash])
  @@unique([contentType, revision])
  @@index([contentType, seasonId, publishedAt])
  @@index([syncRunId])
}

/// 編成使用率。並び順非依存の teamKey と表示順を分離する。
model BattleTeamUsage {
  id              String  @id @default(cuid())
  snapshotId      String
  teamKey         String
  usageRate       Float
  usageCount      Int?
  rank            Int?
  side            String?
  stageKey        String?
  scopeKey        String
  sampleSize      Int?
  isResolved      Boolean @default(true)
  sourceMetadata  Json

  snapshot BattleStatsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)
  members  BattleTeamMember[]

  @@unique([snapshotId, teamKey, scopeKey])
  @@index([snapshotId, usageRate])
  @@index([snapshotId, side, stageKey])
}

model BattleTeamMember {
  id            String @id @default(cuid())
  teamUsageId   String
  characterId   String
  slot          Int
  displayOrder  Int

  teamUsage BattleTeamUsage @relation(fields: [teamUsageId], references: [id], onDelete: Cascade)

  @@unique([teamUsageId, characterId])
  @@unique([teamUsageId, slot])
  @@index([characterId, teamUsageId])
}

model BattleCharacterUsage {
  id                    String  @id @default(cuid())
  snapshotId            String
  characterId           String
  usageRate             Float
  usageCount            Int?
  rank                  Int?
  side                  String?
  scopeKey              String
  ownershipRate         Float?
  usageAmongOwnersRate  Float?
  sampleSize            Int?
  isResolved            Boolean @default(true)

  snapshot BattleStatsSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@unique([snapshotId, characterId, scopeKey])
  @@index([snapshotId, usageRate])
  @@index([characterId, snapshotId])
}

/// 検証済み最新スナップショットだけを指す公開ポインタ。
model BattleStatsManifest {
  contentType          String   @id
  publishedSnapshotId String   @unique
  revision            Int
  payloadHash          String
  schemaVersion        Int
  seasonId             String
  updatedAt            DateTime @updatedAt

  publishedSnapshot BattleStatsSnapshot @relation(fields: [publishedSnapshotId], references: [id], onDelete: Restrict)
}
